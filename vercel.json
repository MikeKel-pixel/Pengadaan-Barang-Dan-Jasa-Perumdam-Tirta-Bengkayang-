{
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.6.1"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "api/index.php"
        }
    ],
    "outputDirectory": "public"
}