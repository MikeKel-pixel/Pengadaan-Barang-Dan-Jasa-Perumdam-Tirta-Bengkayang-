{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "php"
        },
        {
            "src": "public/**",
            "use": "static"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "api/index.php"
        }
    ]
}